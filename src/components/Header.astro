---
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 dark:bg-slate-950/80 backdrop-blur-xl border-b border-slate-200 dark:border-white/10 w-full transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
        <div class="flex-shrink-0 flex items-center">
          <a href="/" class="flex items-center gap-2 group">
            <div class="w-6 h-6 rounded-md bg-slate-900 dark:bg-white flex items-center justify-center shadow-md transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white dark:text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <span class="text-lg font-medium text-slate-900 dark:text-white tracking-tight">Open Source</span>
          </a>
        </div>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center space-x-6 h-full">
        <!-- Explore Menu -->
        <div class="relative group h-full flex items-center">
          <button class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors h-full flex items-center gap-1 focus:outline-none">
            Explore
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-slate-400 group-hover:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="absolute top-16 left-1/2 -translate-x-1/2 w-[540px] bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 rounded-2xl shadow-xl p-6 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 z-50">
            <div class="grid grid-cols-12 gap-6">
              <!-- Left side -->
              <div class="col-span-6 space-y-4">
                <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest block">Browse by Focus</span>
                <div class="flex flex-col gap-2">
                  <a href="/" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-indigo-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">All Alternatives</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">View our entire mapped database</span>
                    </div>
                  </a>
                  <a href="/category/hosting-devops" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">Self-Hostable</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Fully control and host your own data</span>
                    </div>
                  </a>
                  <a href="/category/backend-as-a-service" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-amber-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">Developer Stacks</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Open source frameworks for builders</span>
                    </div>
                  </a>
                </div>
              </div>
              
              <!-- Right side (Featured) -->
              <div class="col-span-6 bg-slate-50 dark:bg-white/[0.02] border border-slate-100 dark:border-white/[0.05] rounded-xl p-4 flex flex-col justify-between">
                <div>
                  <span class="text-[9px] font-bold text-indigo-500 dark:text-indigo-400 uppercase tracking-widest bg-indigo-50 dark:bg-indigo-500/10 px-2 py-0.5 rounded">Featured Stack</span>
                  <h4 class="text-sm font-bold text-slate-900 dark:text-white mt-3 leading-tight">Supabase + PostHog</h4>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 leading-relaxed">
                    Deploy a fully open-source backend database and feature-rich product analytics in under 15 minutes.
                  </p>
                </div>
                <a href="/alternative-to/firebase" class="text-xs font-bold text-indigo-500 dark:text-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-300 mt-4 flex items-center gap-1">
                  Learn more
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Alternatives Menu -->
        <div class="relative group h-full flex items-center">
          <button class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors h-full flex items-center gap-1 focus:outline-none">
            Alternatives
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-slate-400 group-hover:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="absolute top-16 left-1/2 -translate-x-1/2 w-[540px] bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 rounded-2xl shadow-xl p-6 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 z-50">
            <div class="grid grid-cols-12 gap-6">
              <!-- Left side -->
              <div class="col-span-7 space-y-4">
                <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest block">Popular Alternatives</span>
                <div class="flex flex-col gap-2">
                  <a href="/alternative-to/notion" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-blue-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">Notion Alternatives</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Open source workspace and notes</span>
                    </div>
                  </a>
                  <a href="/alternative-to/slack" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-purple-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">Slack Alternatives</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Team communication tools</span>
                    </div>
                  </a>
                  <a href="/alternative-to/firebase" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-yellow-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">Firebase Alternatives</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Backend-as-a-service platforms</span>
                    </div>
                  </a>
                </div>
              </div>
              
              <!-- Right side (Featured) -->
              <div class="col-span-5 bg-slate-50 dark:bg-white/[0.02] border border-slate-100 dark:border-white/[0.05] rounded-xl p-4 flex flex-col justify-between">
                <div>
                  <span class="text-[9px] font-bold text-indigo-500 dark:text-indigo-400 uppercase tracking-widest bg-indigo-50 dark:bg-indigo-500/10 px-2 py-0.5 rounded">Trending</span>
                  <h4 class="text-sm font-bold text-slate-900 dark:text-white mt-3 leading-tight">Supabase vs Firebase</h4>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 leading-relaxed">
                    Compare the most popular open-source Firebase alternative for your next project.
                  </p>
                </div>
                <a href="/alternative-to/firebase" class="text-xs font-bold text-indigo-500 dark:text-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-300 mt-4 flex items-center gap-1">
                  View comparison
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Categories Menu -->
        <div class="relative group h-full flex items-center">
          <button class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors h-full flex items-center gap-1 focus:outline-none">
            Categories
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-slate-400 group-hover:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="absolute top-16 left-1/2 -translate-x-1/2 w-[540px] bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 rounded-2xl shadow-xl p-6 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 z-50">
            <div class="grid grid-cols-12 gap-6">
              <!-- Left side -->
              <div class="col-span-7 space-y-4">
                <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest block text-left">Top Categories</span>
                <div class="flex flex-col gap-2">
                  <a href="/category/crm" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-rose-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">CRM & Sales</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Manage customer relationships</span>
                    </div>
                  </a>
                  <a href="/category/analytics" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-sky-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">Analytics</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Track and analyze user data</span>
                    </div>
                  </a>
                  <a href="/category/hosting-devops" class="flex items-center gap-2.5 p-2 rounded-xl hover:bg-slate-50 dark:hover:bg-white/[0.03] transition-colors group/link">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 group-hover/link:scale-125 transition-transform"></span>
                    <div class="text-left">
                      <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">Hosting & DevOps</span>
                      <span class="block text-xs text-slate-400 dark:text-slate-500">Deploy and manage apps</span>
                    </div>
                  </a>
                </div>
              </div>
              
              <!-- Right side (Featured) -->
              <div class="col-span-5 bg-slate-50 dark:bg-white/[0.02] border border-slate-100 dark:border-white/[0.05] rounded-xl p-4 flex flex-col justify-between">
                <div>
                  <span class="text-[9px] font-bold text-indigo-500 dark:text-indigo-400 uppercase tracking-widest bg-indigo-50 dark:bg-indigo-500/10 px-2 py-0.5 rounded">New Category</span>
                  <h4 class="text-sm font-bold text-slate-900 dark:text-white mt-3 leading-tight">AI & Machine Learning</h4>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 leading-relaxed">
                    Discover open-source models, tools, and platforms for AI development.
                  </p>
                </div>
                <a href="/category/ai" class="text-xs font-bold text-indigo-500 dark:text-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-300 mt-4 flex items-center gap-1">
                  Explore AI tools
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <a href="#" class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">Stacks</a>
        <a href="#" class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">Self-Hosted</a>
        <a href="/submit" class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">Sponsor</a>
      </nav>

      <!-- CTA & Theme Toggle -->
      <div class="flex items-center gap-4">
        <!-- Theme Toggle -->
        <button id="themeToggle" class="p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="Toggle theme">
            <!-- Sun icon for dark mode (shows when dark is active) -->
            <svg id="sunIcon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <!-- Moon icon for light mode (shows when light is active) -->
            <svg id="moonIcon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
        </button>

        <a href="/submit" class="hidden sm:inline-flex items-center px-4 py-2 border border-slate-200 dark:border-white/10 text-sm font-medium rounded-lg text-slate-700 dark:text-white bg-white dark:bg-white/5 hover:bg-slate-50 dark:hover:bg-white/10 shadow-sm transition-all">
          Submit a Tool
        </a>

        <!-- Mobile Menu Toggle -->
        <button id="mobileMenuBtn" class="md:hidden p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="Toggle mobile menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu (Hidden by default) -->
  <div id="mobileMenu" class="hidden md:hidden border-t border-slate-200 dark:border-white/10 bg-white dark:bg-slate-950 px-4 py-6 space-y-6 max-h-[calc(100vh-4rem)] overflow-y-auto">
    <div class="flex flex-col space-y-4">
      <div class="space-y-3">
        <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest block">Explore</span>
        <div class="flex flex-col gap-2 pl-2 border-l border-slate-200 dark:border-slate-800">
          <a href="/" class="text-sm font-medium text-slate-700 dark:text-slate-300">All Alternatives</a>
          <a href="/category/hosting-devops" class="text-sm font-medium text-slate-700 dark:text-slate-300">Self-Hostable</a>
          <a href="/category/backend-as-a-service" class="text-sm font-medium text-slate-700 dark:text-slate-300">Developer Stacks</a>
        </div>
      </div>
      
      <div class="space-y-3">
        <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest block">Alternatives</span>
        <div class="flex flex-col gap-2 pl-2 border-l border-slate-200 dark:border-slate-800">
          <a href="/alternative-to/notion" class="text-sm font-medium text-slate-700 dark:text-slate-300">Notion Alternatives</a>
          <a href="/alternative-to/slack" class="text-sm font-medium text-slate-700 dark:text-slate-300">Slack Alternatives</a>
          <a href="/alternative-to/firebase" class="text-sm font-medium text-slate-700 dark:text-slate-300">Firebase Alternatives</a>
        </div>
      </div>

      <div class="space-y-3">
        <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest block">Categories</span>
        <div class="flex flex-col gap-2 pl-2 border-l border-slate-200 dark:border-slate-800">
          <a href="/category/crm" class="text-sm font-medium text-slate-700 dark:text-slate-300">CRM & Sales</a>
          <a href="/category/analytics" class="text-sm font-medium text-slate-700 dark:text-slate-300">Analytics</a>
          <a href="/category/hosting-devops" class="text-sm font-medium text-slate-700 dark:text-slate-300">Hosting & DevOps</a>
        </div>
      </div>

      <div class="pt-4 flex flex-col gap-3">
        <a href="#" class="text-sm font-medium text-slate-700 dark:text-slate-300">Stacks</a>
        <a href="#" class="text-sm font-medium text-slate-700 dark:text-slate-300">Self-Hosted</a>
        <a href="/submit" class="text-sm font-medium text-slate-700 dark:text-slate-300">Sponsor</a>
        <a href="/submit" class="text-sm font-bold text-indigo-500 dark:text-indigo-400 mt-2 sm:hidden">Submit a Tool</a>
      </div>
    </div>
  </div>
</header>

<script>
    const themeToggle = document.getElementById('themeToggle');
    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const html = document.documentElement;
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        });
    }

    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    
    if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    }
</script>
