---
import Layout from '../../layouts/Layout.astro';
import saasData from '../../data/saas.json';

export async function getStaticPaths() {
  // Extract all unique categories
  const allCategories = [...new Set(saasData.map((item) => item.category))];

  return allCategories.map((category) => {
    // Generate a URL-friendly slug
    const slug = category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
    
    // Get all items in this category
    const items = saasData.filter((item) => item.category === category);
    
    return {
      params: { category: slug },
      props: { name: category, items },
    };
  });
}

const { name, items } = Astro.props;
const totalReplacements = items.reduce((acc, curr) => acc + curr.alternatives.length, 0);
---

<Layout title={`${name} Open Source Alternatives`} description={`Find the best open-source and free alternatives for ${name} software.`}>
    <main class="max-w-6xl mx-auto py-24 px-4 relative">
        <div class="mb-8">
            <a href="/" class="group inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to all categories
            </a>
        </div>

        <div class="mb-16">
            <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-6">
                Open Source <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-purple-500 dark:from-indigo-400 dark:to-purple-400">{name}</span> Alternatives
            </h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
                We found {items.length} expensive {name} tools and mapped them to {totalReplacements} privacy-friendly, open-source alternatives.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10">
            {items.map((item, index) => (
                <a href={`/alternative-to/${item.slug}`} class="saas-card block group relative bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-all duration-300 shadow-sm hover:shadow-xl hover:-translate-y-1 overflow-hidden">
                    <div class="p-6 h-full flex flex-col justify-between relative z-10">
                        <div>
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800/80 flex items-center justify-center text-slate-700 dark:text-slate-300 font-bold text-lg border border-slate-200 dark:border-slate-700/50">
                                    {item.name.charAt(0)}
                                </div>
                                <div>
                                    <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-1.5 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                                        {item.name}
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                        </svg>
                                    </h3>
                                    <span class="text-[10px] font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded uppercase tracking-wider">{item.category}</span>
                                </div>
                            </div>
                            
                            <div class="relative h-12 overflow-hidden">
                                <p class="absolute inset-0 text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-2 transition-all duration-300 group-hover:opacity-0 group-hover:translate-y-[-10px] group-hover:pointer-events-none">
                                    Replace proprietary and expensive {item.name} with free, open-source alternatives.
                                </p>
                                <div class="absolute inset-0 opacity-0 translate-y-[10px] transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0 pointer-events-none group-hover:pointer-events-auto flex flex-col justify-center">
                                    <span class="text-[10px] font-bold uppercase tracking-wider text-indigo-600 dark:text-indigo-400 mb-0.5">SaaS Alternatives</span>
                                    <p class="text-slate-800 dark:text-slate-200 text-xs leading-relaxed line-clamp-2 font-medium">
                                        Replaced by {item.alternatives.map(a => a.name).join(', ')}.
                                    </p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-8 flex flex-col space-y-2 text-xs text-slate-500 dark:text-slate-400 font-mono">
                            <div class="flex justify-between items-center">
                                <span>Available alternatives</span>
                                <div class="flex-grow border-b border-dotted border-slate-200 dark:border-slate-700/50 mx-2 translate-y-[2px]"></div>
                                <span class="font-bold text-slate-900 dark:text-white">{item.alternatives.length} tools</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span>Privacy focus</span>
                                <div class="flex-grow border-b border-dotted border-slate-200 dark:border-slate-700/50 mx-2 translate-y-[2px]"></div>
                                <span class="font-bold text-emerald-600 dark:text-emerald-400 flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                    </svg>
                                    Self-host
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </main>
</Layout>
