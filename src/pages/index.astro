---
import Layout from '../layouts/Layout.astro';
import saasData from '../data/saas.json';
---
<Layout>
    <main class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
                Open Source <span class="text-indigo-600">Alternatives</span>
            </h1>
            <p class="text-xl text-gray-500 max-w-2xl mx-auto">
                Discover free, open-source, and privacy-friendly alternatives to the most expensive SaaS applications on the market.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {saasData.map((item) => (
                <a href={`/alternative-to/${item.slug}`} class="block group">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg hover:border-indigo-300 transition-all p-6 h-full flex flex-col justify-between">
                        <div>
                            <span class="text-xs font-semibold tracking-wide uppercase text-indigo-600 mb-2 block">{item.category}</span>
                            <h2 class="text-2xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors">
                                Alternative to {item.name}
                            </h2>
                        </div>
                        <div class="mt-4 text-sm text-gray-500">
                            {item.alternatives.length} {item.alternatives.length === 1 ? 'Alternative' : 'Alternatives'} inside &rarr;
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </main>
</Layout>
