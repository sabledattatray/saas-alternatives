---
import Layout from '../layouts/Layout.astro';
import saasData from '../data/saas.json';

// Extract unique categories
const categories = ["All", ...new Set(saasData.map(item => item.category))];
const totalReplacements = saasData.reduce((acc, curr) => acc + curr.alternatives.length, 0);
---
<Layout>
    <main class="max-w-7xl mx-auto py-24 px-4 sm:px-6 lg:px-8 relative">
        
        <!-- Hero Section with Background Pattern -->
        <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-20">
            <svg class="absolute left-[50%] top-0 h-[48rem] max-w-none -translate-x-1/2 stroke-indigo-500/20" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
                  <path d="M.5 40V.5H40" fill="none"></path>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
            </svg>
        </div>

        <div class="text-center mb-24 relative z-10 pt-10">
            <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-indigo-500/30 bg-indigo-500/10 backdrop-blur-md text-sm text-indigo-300 font-medium mb-8 hover:bg-indigo-500/20 transition-colors shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                <span class="relative flex h-2 w-2 mr-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                </span>
                Mapping {saasData.length} SaaS giants to {totalReplacements} open-source alternatives
            </div>
            
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-tight">
                Escape the <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 drop-shadow-sm">SaaS Tax</span>.<br/> Own your software.
            </h1>
            
            <p class="text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto font-light leading-relaxed">
                Stop paying exorbitant subscription fees. We map the world's most expensive software to their finest privacy-friendly, open-source replacements.
            </p>
        </div>

        <!-- Filters & Search Section -->
        <div class="sticky top-20 z-40 bg-slate-950/80 backdrop-blur-xl border-b border-white/5 py-4 mb-12 -mx-4 px-4 sm:mx-0 sm:px-0 sm:bg-transparent sm:backdrop-blur-none sm:border-none sm:py-0">
            
            <!-- Search Bar -->
            <div class="max-w-2xl mx-auto mb-8 relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400 group-focus-within:text-indigo-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input 
                    type="text" 
                    id="searchInput"
                    placeholder="Search for Notion, Jira, Vercel..." 
                    class="block w-full pl-12 pr-4 py-4 rounded-2xl bg-slate-900/80 backdrop-blur-md border border-white/10 text-white placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all shadow-xl text-lg outline-none"
                >
            </div>

            <!-- Category Pills -->
            <div class="flex overflow-x-auto pb-4 hide-scrollbar justify-start lg:justify-center gap-3">
                {categories.map((category) => (
                    <button 
                        class="category-pill whitespace-nowrap px-6 py-2.5 rounded-full border border-white/10 text-sm font-medium transition-all duration-300"
                        data-category={category.toLowerCase()}
                    >
                        {category}
                    </button>
                ))}
            </div>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10" id="directoryGrid">
            {saasData.map((item) => (
                <a href={`/alternative-to/${item.slug}`} class="saas-card block group relative rounded-3xl p-[1px] overflow-hidden transition-all duration-500 shadow-2xl shadow-black/40 hover:-translate-y-1 hover:shadow-indigo-500/20" data-name={item.name.toLowerCase()} data-category={item.category.toLowerCase()}>
                    <!-- Gradient Border -->
                    <div class="absolute inset-0 bg-gradient-to-b from-white/10 to-transparent group-hover:from-indigo-500 group-hover:to-purple-500 transition-colors duration-500"></div>
                    
                    <div class="relative bg-slate-900/95 backdrop-blur-xl rounded-[23px] p-8 h-full flex flex-col justify-between border border-white/5 group-hover:border-transparent transition-colors z-10 overflow-hidden">
                        
                        <!-- Decorative Top Glow -->
                        <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover:via-indigo-400 transition-colors"></div>
                        <div class="absolute -top-10 -right-10 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl group-hover:bg-indigo-500/30 transition-colors"></div>

                        <div>
                            <span class="inline-block px-3 py-1 rounded-md bg-white/5 text-slate-300 text-xs font-semibold tracking-wider uppercase mb-5 border border-white/10 group-hover:bg-indigo-500/10 group-hover:text-indigo-300 group-hover:border-indigo-500/20 transition-all">
                                {item.category}
                            </span>
                            
                            <h2 class="text-3xl font-extrabold text-white group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-indigo-300 group-hover:to-purple-300 transition-all">
                                {item.name}
                            </h2>
                            <p class="text-slate-400 mt-2 text-sm font-medium uppercase tracking-widest opacity-60">Replaced By</p>
                        </div>
                        
                        <div class="mt-12 flex items-center justify-between">
                            <div class="flex items-center">
                                <div class="flex -space-x-3">
                                    {item.alternatives.map((alt, index) => (
                                        <div class="w-10 h-10 rounded-full border-2 border-slate-900 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-xs font-bold text-white shadow-lg relative z-[{10 - index}]">
                                            {alt.name.charAt(0)}
                                        </div>
                                    ))}
                                </div>
                                <span class="ml-4 text-sm font-medium text-slate-300 group-hover:text-white transition-colors">
                                    {item.alternatives.length} {item.alternatives.length === 1 ? 'Tool' : 'Tools'}
                                </span>
                            </div>
                            
                            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center border border-white/10 group-hover:bg-indigo-500 group-hover:border-indigo-400 transition-all duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                </svg>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
        
        <!-- Empty State -->
        <div id="emptyState" class="hidden text-center py-32 relative z-10">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-800/50 border border-white/10 mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
            </div>
            <h3 class="text-3xl font-bold text-white mb-3">No software found</h3>
            <p class="text-slate-400 text-lg">We haven't mapped an alternative for this tool yet.</p>
            <a href="/submit" class="mt-8 inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-xl text-white bg-indigo-600 hover:bg-indigo-500 shadow-lg shadow-indigo-500/30 transition-all">
                Submit a Request
            </a>
        </div>
    </main>

    <style>
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</Layout>

<script>
    // Client-side filtering logic
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const cards = document.querySelectorAll('.saas-card') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('emptyState');
    const pills = document.querySelectorAll('.category-pill') as NodeListOf<HTMLElement>;
    
    let currentCategory = 'all';
    let currentSearch = '';

    // Initialize pills
    pills.forEach(pill => {
        if (pill.getAttribute('data-category') === 'all') {
            pill.classList.add('bg-indigo-600', 'text-white', 'border-indigo-500', 'shadow-lg', 'shadow-indigo-500/30');
        } else {
            pill.classList.add('bg-slate-900/50', 'text-slate-400', 'hover:text-white', 'hover:bg-slate-800', 'border-white/10');
        }

        pill.addEventListener('click', () => {
            currentCategory = pill.getAttribute('data-category') || 'all';
            
            // Update active state
            pills.forEach(p => {
                p.className = 'category-pill whitespace-nowrap px-6 py-2.5 rounded-full border text-sm font-medium transition-all duration-300';
                if (p.getAttribute('data-category') === currentCategory) {
                    p.classList.add('bg-indigo-600', 'text-white', 'border-indigo-500', 'shadow-lg', 'shadow-indigo-500/30');
                } else {
                    p.classList.add('bg-slate-900/50', 'text-slate-400', 'hover:text-white', 'hover:bg-slate-800', 'border-white/10');
                }
            });

            filterCards();
        });
    });

    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
            filterCards();
        });
    }

    function filterCards() {
        let visibleCount = 0;

        cards.forEach(card => {
            const name = card.getAttribute('data-name') || '';
            const category = card.getAttribute('data-category') || '';
            
            const matchesSearch = name.includes(currentSearch) || category.includes(currentSearch);
            const matchesCategory = currentCategory === 'all' || category === currentCategory;

            if (matchesSearch && matchesCategory) {
                card.style.display = 'block';
                // Trigger a tiny reflow to restart fade-in animation
                card.style.opacity = '0';
                setTimeout(() => card.style.opacity = '1', 10);
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        if (emptyState) {
            emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
        }
    }
</script>
