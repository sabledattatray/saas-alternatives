---
import Layout from '../layouts/Layout.astro';
import saasData from '../data/saas.json';

// Extract unique categories
const categories = ["All", ...new Set(saasData.map(item => item.category))];
const totalReplacements = saasData.reduce((acc, curr) => acc + curr.alternatives.length, 0);

// Extract unique open-source alternatives
const uniqueAlternatives = [];
const seenAlts = new Set();
for (const saas of saasData) {
    for (const alt of saas.alternatives) {
        if (!seenAlts.has(alt.name.toLowerCase())) {
            seenAlts.add(alt.name.toLowerCase());
            uniqueAlternatives.push({
                ...alt,
                parentSaas: saas.name,
                parentSlug: saas.slug,
                category: saas.category
            });
        }
    }
}
---
<Layout>
    <main class="max-w-7xl mx-auto py-24 px-4 sm:px-6 lg:px-8 relative">
        
        <!-- Hero Section with Background Pattern -->
        <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-10 dark:opacity-20 transition-opacity">
            <svg class="absolute left-[50%] top-0 h-[48rem] max-w-none -translate-x-1/2 stroke-indigo-500/20" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
                  <path d="M.5 40V.5H40" fill="none"></path>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
            </svg>
        </div>

        <div class="text-center mb-24 relative z-10 pt-10">
            <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-indigo-500/20 bg-indigo-50 dark:bg-indigo-500/10 backdrop-blur-md text-sm text-indigo-700 dark:text-indigo-300 font-medium mb-8 hover:bg-indigo-100 dark:hover:bg-indigo-500/20 transition-colors shadow-sm dark:shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                <span class="relative flex h-2 w-2 mr-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                </span>
                Mapping {saasData.length} SaaS giants to {totalReplacements} open-source alternatives
            </div>
            
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6 leading-tight text-slate-900 dark:text-white transition-colors">
                Discover Open Source Replacements <br class="hidden md:block" /> for Proprietary Software
            </h1>
            
            <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-light leading-relaxed mb-10 transition-colors">
                Over 1 million users replaced their proprietary tools with open source software. Discover the best alternatives and join the movement.
            </p>

            <!-- Subscribe Box -->
            <div class="max-w-md mx-auto">
                <form class="flex items-center bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-white/10 shadow-sm overflow-hidden p-1 transition-colors">
                    <input type="email" placeholder="Enter your email" class="flex-grow bg-transparent border-none outline-none px-4 py-2 text-slate-900 dark:text-white placeholder-slate-400" required>
                    <button type="submit" class="bg-orange-700 hover:bg-orange-800 text-white px-6 py-2 rounded-md font-medium transition-colors shadow-sm">
                        Subscribe
                    </button>
                </form>
                <div class="flex items-center justify-center mt-3 text-sm text-slate-500 dark:text-slate-400">
                    <div class="flex -space-x-2 mr-3">
                        <div class="w-6 h-6 rounded-full bg-slate-200 border-2 border-slate-50 dark:border-slate-950"></div>
                        <div class="w-6 h-6 rounded-full bg-slate-300 border-2 border-slate-50 dark:border-slate-950"></div>
                        <div class="w-6 h-6 rounded-full bg-slate-400 border-2 border-slate-50 dark:border-slate-950"></div>
                    </div>
                    Trusted by 12K+ people
                </div>
            </div>

            <!-- Trusted By Logos -->
            <div class="mt-20 pt-10 border-t border-slate-200 dark:border-white/5">
                <p class="text-xs font-semibold text-slate-400 dark:text-slate-500 mb-6 uppercase tracking-[0.2em] text-center">Supported by these incredible partners</p>
                <div class="flex flex-wrap justify-center gap-3 md:gap-4 items-center max-w-4xl mx-auto px-4">
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-indigo-500 dark:text-indigo-400 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13h-13L12 6.5z"/></svg>
                        <span class="text-xs font-bold tracking-tight">Prismical</span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-emerald-500 dark:text-emerald-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7v4c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 11v4c0 2.21 3.582 4 8 4s8-1.79 8-4v-4" /></svg>
                        <span class="text-xs font-bold tracking-tight">Databuddy</span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-amber-600 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-amber-500 dark:text-amber-400 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Zm3 10.5a3 3 0 1 1-6 0v-3a3 3 0 0 1 6 0v3Z" clip-rule="evenodd" /></svg>
                        <span class="text-xs font-bold tracking-tight">Logto</span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-rose-600 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-rose-500 dark:text-rose-400 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2s-8 3-8 9v6c0 3 4 5 8 5s8-2 8-5v-6c0-6-8-9-8-9zm0 18c-3 0-6-1.5-6-3.5v-4.5c0-4.5 6-7 6-7s6 2.5 6 7v4.5c0 2-3 3.5-6 3.5z"/></svg>
                        <span class="text-xs font-bold tracking-tight">Sevalla</span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-emerald-500 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-emerald-500 dark:text-emerald-400 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M13.795 2.102c-.394-.658-1.354-.539-1.579.196l-3.324 10.84a.75.75 0 0 0 .716.97h3.916l-1.927 7.79c-.198.804.887 1.295 1.401.636l7.85-10.05a.75.75 0 0 0-.59-1.21h-4.32l2.857-9.172Z" /></svg>
                        <span class="text-xs font-bold tracking-tight">Supabase</span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-pink-600 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-pink-500 dark:text-pink-400 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12.378 1.602a.75.75 0 00-.756 0L3 6.632l9 5.2 9-5.2-8.622-5.03zM21 8.368l-8.25 4.763v8.136L21 16.5V8.368zM11.25 21.267v-8.136L3 8.368V16.5l8.25 4.767z" /></svg>
                        <span class="text-xs font-bold tracking-tight">Coolify</span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-orange-600 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-orange-500 dark:text-orange-400 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M3 13.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5v-6zm5-4a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v10a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5V9.5zm5-4a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v14a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5V5.5zm5 8a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5v-6z" /></svg>
                        <span class="text-xs font-bold tracking-tight">PostHog</span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100/60 dark:bg-white/[0.02] border border-slate-200/60 dark:border-white/[0.04] text-slate-800 dark:text-slate-300 hover:text-cyan-600 dark:hover:text-white hover:bg-slate-200/80 dark:hover:bg-white/[0.05] hover:border-slate-300 dark:hover:border-white/[0.1] hover:-translate-y-0.5 transition-all duration-300 shadow-sm">
                        <svg class="w-5 h-5 text-cyan-500 dark:text-cyan-400 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M3.478 2.404a.75.75 0 0 0-.92 1.042l7.75 16.25a.75.75 0 0 0 1.392-.026l3.181-7.747 7.747-3.181a.75.75 0 0 0-.026-1.392L6.057 2.65a.75.75 0 0 0-.73.087L3.478 2.404Z" /></svg>
                        <span class="text-xs font-bold tracking-tight">Resend</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Filters & Search Section -->
        <div class="relative z-40 mb-12 pt-4">
            
            <div class="max-w-6xl mx-auto px-4">
                <!-- Search and Filters Bar -->
                <div class="flex flex-col sm:flex-row gap-3 mb-6">
                    <!-- Search Input Box -->
                    <div class="relative group flex-grow">
                        <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-xl blur opacity-0 dark:opacity-20 group-focus-within:opacity-30 dark:group-focus-within:opacity-50 transition duration-500"></div>
                        <div class="relative flex items-center bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-white/10 overflow-hidden shadow-sm dark:shadow-2xl transition-colors h-11">
                            <div class="pl-4 pointer-events-none">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 group-focus-within:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                            <input 
                                type="text" 
                                id="searchInput"
                                placeholder="Search tools..." 
                                class="w-full bg-transparent text-slate-900 dark:text-white placeholder-slate-400 px-3 py-2.5 outline-none text-sm"
                            >
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex gap-3 shrink-0">
                        <!-- Filters Button -->
                        <button class="flex items-center justify-center gap-2 px-4 h-11 bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 rounded-xl text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors shadow-sm dark:shadow-2xl">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
                            Filters
                        </button>
                        
                        <!-- Order by Dropdown -->
                        <div class="relative">
                            <button class="flex items-center justify-between gap-3 px-4 h-11 bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 rounded-xl text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors shadow-sm dark:shadow-2xl">
                                Order by
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-500" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 3a.75.75 0 01.53.22l3.25 3.25a.75.75 0 11-1.06 1.06L10 4.81 7.28 7.53a.75.75 0 01-1.06-1.06l3.25-3.25A.75.75 0 0110 3zm0 14a.75.75 0 01-.53-.22l-3.25-3.25a.75.75 0 111.06-1.06L10 15.19l2.72-2.72a.75.75 0 111.06 1.06l-3.25 3.25A.75.75 0 0110 17z" clip-rule="evenodd" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>


            </div>
        </div>

        <!-- Section 1: Open Source Alternatives -->
        <div id="openSourceSection" class="relative z-10 max-w-6xl mx-auto px-4 mb-20">
            <div class="flex flex-col mb-8">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Popular Open Source Projects</h2>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">High-quality, community-driven, and self-hostable replacements.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="openSourceGrid">
                {uniqueAlternatives.map((item) => (
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="os-card block group relative bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-all duration-300 shadow-sm hover:shadow-xl hover:-translate-y-1 overflow-hidden" data-name={item.name.toLowerCase()} data-category={item.category.toLowerCase()} data-parent={item.parentSaas.toLowerCase()}>
                        <div class="p-6 h-full flex flex-col justify-between relative z-10">
                            <div>
                                <div class="flex items-center gap-3 mb-4">
                                    <div class="w-10 h-10 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 font-bold text-lg border border-indigo-100 dark:border-indigo-500/20">
                                        {item.name.charAt(0)}
                                    </div>
                                    <div>
                                        <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-1.5 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                                            {item.name}
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-slate-400 group-hover:text-indigo-500 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                            </svg>
                                        </h3>
                                        <span class="text-[10px] font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded uppercase tracking-wider">{item.category}</span>
                                    </div>
                                </div>
                                
                                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-2">
                                    {item.description}
                                </p>
                            </div>
                            
                            <div class="mt-8 flex flex-col space-y-2 text-xs text-slate-500 dark:text-slate-400 font-mono">
                                <div class="flex justify-between items-center">
                                    <span>Alternative to</span>
                                    <div class="flex-grow border-b border-dotted border-slate-200 dark:border-slate-700/50 mx-2 translate-y-[2px]"></div>
                                    <span class="font-bold text-indigo-600 dark:text-indigo-400">{item.parentSaas}</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Pricing</span>
                                    <div class="flex-grow border-b border-dotted border-slate-200 dark:border-slate-700/50 mx-2 translate-y-[2px]"></div>
                                    <span class="font-bold text-slate-900 dark:text-white">{item.pricing}</span>
                                </div>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>

        <!-- Section Divider -->
        <div id="sectionDivider" class="relative z-10 max-w-6xl mx-auto px-4 mb-20">
            <div class="border-t border-slate-200 dark:border-white/5"></div>
        </div>

        <!-- Section 2: SaaS Platforms -->
        <div id="saasSection" class="relative z-10 max-w-6xl mx-auto px-4 mb-24">
            <div class="flex flex-col mb-8">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">People are looking for alternatives to...</h2>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Discover open-source replacements for proprietary SaaS and commercial tools.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="saasGrid">
                {saasData.map((item) => (
                    <a href={`/alternative-to/${item.slug}`} class="saas-card block group relative bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-all duration-300 shadow-sm hover:shadow-xl hover:-translate-y-1 overflow-hidden" data-name={item.name.toLowerCase()} data-category={item.category.toLowerCase()}>
                        
                        <div class="p-6 h-full flex flex-col justify-between relative z-10">
                            
                            <div>
                                <div class="flex items-center gap-3 mb-4">
                                    <div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800/80 flex items-center justify-center text-slate-700 dark:text-slate-300 font-bold text-lg border border-slate-200 dark:border-slate-700/50">
                                        {item.name.charAt(0)}
                                    </div>
                                    <div>
                                        <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-1.5 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                                            {item.name}
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
                                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                            </svg>
                                        </h3>
                                        <span class="text-[10px] font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded uppercase tracking-wider">{item.category}</span>
                                    </div>
                                </div>
                                
                                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-2">
                                    Replace proprietary and expensive {item.name} with free, open-source alternatives.
                                </p>
                            </div>
                            
                            <div class="mt-8 flex flex-col space-y-2 text-xs text-slate-500 dark:text-slate-400 font-mono">
                                <div class="flex justify-between items-center">
                                    <span>Available alternatives</span>
                                    <div class="flex-grow border-b border-dotted border-slate-200 dark:border-slate-700/50 mx-2 translate-y-[2px]"></div>
                                    <span class="font-bold text-slate-900 dark:text-white">{item.alternatives.length} tools</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Privacy focus</span>
                                    <div class="flex-grow border-b border-dotted border-slate-200 dark:border-slate-700/50 mx-2 translate-y-[2px]"></div>
                                    <span class="font-bold text-emerald-600 dark:text-emerald-400 flex items-center gap-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                        </svg>
                                        Self-host
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
        
        <!-- Empty State -->
        <div id="emptyState" class="hidden text-center py-32 relative z-10">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-white/10 mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
            </div>
            <h3 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">No software found</h3>
            <p class="text-slate-500 dark:text-slate-400 text-lg">We haven't mapped an alternative for this tool yet.</p>
            <a href="/submit" class="mt-8 inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-xl text-white bg-indigo-600 hover:bg-indigo-700 shadow-lg shadow-indigo-500/30 transition-all">
                Submit a Request
            </a>
        </div>
    </main>

    <style>
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .mask-edges {
            -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
            mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
        }
    </style>
</Layout>

<script>
    // Client-side filtering logic
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const osCards = document.querySelectorAll('.os-card') as NodeListOf<HTMLElement>;
    const saasCards = document.querySelectorAll('.saas-card') as NodeListOf<HTMLElement>;

    const openSourceSection = document.getElementById('openSourceSection');
    const saasSection = document.getElementById('saasSection');
    const sectionDivider = document.getElementById('sectionDivider');
    const emptyState = document.getElementById('emptyState');
    let currentSearch = '';

    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
            filterCards();
        });
    }

    function filterCards() {
        let visibleOsCount = 0;
        let visibleSaasCount = 0;

        osCards.forEach(card => {
            const name = card.getAttribute('data-name') || '';
            const category = card.getAttribute('data-category') || '';
            const parent = card.getAttribute('data-parent') || '';
            
            const matchesSearch = name.includes(currentSearch) || category.includes(currentSearch) || parent.includes(currentSearch);

            if (matchesSearch) {
                card.style.display = 'block';
                visibleOsCount++;
            } else {
                card.style.display = 'none';
            }
        });

        saasCards.forEach(card => {
            const name = card.getAttribute('data-name') || '';
            const category = card.getAttribute('data-category') || '';
            
            const matchesSearch = name.includes(currentSearch) || category.includes(currentSearch);

            if (matchesSearch) {
                card.style.display = 'block';
                visibleSaasCount++;
            } else {
                card.style.display = 'none';
            }
        });

        // Hide or show sections dynamically based on search results
        if (openSourceSection) {
            openSourceSection.style.display = visibleOsCount === 0 ? 'none' : 'block';
        }
        if (saasSection) {
            saasSection.style.display = visibleSaasCount === 0 ? 'none' : 'block';
        }
        if (sectionDivider) {
            sectionDivider.style.display = (visibleOsCount === 0 || visibleSaasCount === 0) ? 'none' : 'block';
        }

        if (emptyState) {
            emptyState.style.display = (visibleOsCount === 0 && visibleSaasCount === 0) ? 'block' : 'none';
        }
    }
</script>
