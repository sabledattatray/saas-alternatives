---
import Layout from '../layouts/Layout.astro';
import saasData from '../data/saas.json';

// Extract unique categories
const categories = ["All", ...new Set(saasData.map(item => item.category))];
const totalReplacements = saasData.reduce((acc, curr) => acc + curr.alternatives.length, 0);
---
<Layout>
    <main class="max-w-7xl mx-auto py-24 px-4 sm:px-6 lg:px-8 relative">
        
        <!-- Hero Section with Background Pattern -->
        <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-10 dark:opacity-20 transition-opacity">
            <svg class="absolute left-[50%] top-0 h-[48rem] max-w-none -translate-x-1/2 stroke-indigo-500/20" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
                  <path d="M.5 40V.5H40" fill="none"></path>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
            </svg>
        </div>

        <div class="text-center mb-24 relative z-10 pt-10">
            <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-indigo-500/20 bg-indigo-50 dark:bg-indigo-500/10 backdrop-blur-md text-sm text-indigo-700 dark:text-indigo-300 font-medium mb-8 hover:bg-indigo-100 dark:hover:bg-indigo-500/20 transition-colors shadow-sm dark:shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                <span class="relative flex h-2 w-2 mr-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                </span>
                Mapping {saasData.length} SaaS giants to {totalReplacements} open-source alternatives
            </div>
            
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight text-slate-900 dark:text-white transition-colors">
                Open Source Alternatives <br class="hidden md:block" /> to Popular Software
            </h1>
            
            <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-light leading-relaxed mb-10 transition-colors">
                Over 1 million users replaced their proprietary tools with open source software. Discover the best alternatives and join the movement.
            </p>

            <!-- Subscribe Box -->
            <div class="max-w-md mx-auto">
                <form class="flex items-center bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-white/10 shadow-sm overflow-hidden p-1 transition-colors">
                    <input type="email" placeholder="Enter your email" class="flex-grow bg-transparent border-none outline-none px-4 py-2 text-slate-900 dark:text-white placeholder-slate-400" required>
                    <button type="submit" class="bg-orange-700 hover:bg-orange-800 text-white px-6 py-2 rounded-md font-medium transition-colors shadow-sm">
                        Subscribe
                    </button>
                </form>
                <div class="flex items-center justify-center mt-3 text-sm text-slate-500 dark:text-slate-400">
                    <div class="flex -space-x-2 mr-3">
                        <div class="w-6 h-6 rounded-full bg-slate-200 border-2 border-slate-50 dark:border-slate-950"></div>
                        <div class="w-6 h-6 rounded-full bg-slate-300 border-2 border-slate-50 dark:border-slate-950"></div>
                        <div class="w-6 h-6 rounded-full bg-slate-400 border-2 border-slate-50 dark:border-slate-950"></div>
                    </div>
                    Trusted by 12K+ people
                </div>
            </div>

            <!-- Trusted By Logos -->
            <div class="mt-20 pt-10 border-t border-slate-200 dark:border-white/5">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-6 uppercase tracking-wider">Supported by these incredible partners</p>
                <div class="flex flex-wrap justify-center gap-8 md:gap-16 items-center opacity-60 dark:opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
                    <div class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13h-13L12 6.5z"/></svg>Prismical</div>
                    <div class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 18a8 8 0 110-16 8 8 0 010 16z"/></svg>Databuddy</div>
                    <div class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M4 4h16v16H4V4zm2 2v12h12V6H6z"/></svg>Logto</div>
                    <div class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Sevalla</div>
                </div>
            </div>
        </div>

        <!-- Filters & Search Section -->
        <div class="relative z-40 mb-12 pt-4">
            
            <div class="max-w-5xl mx-auto px-4 sm:px-6">
                <!-- Search Bar -->
                <div class="relative group max-w-5xl mx-auto mb-6">
                    <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-xl blur opacity-0 dark:opacity-20 group-focus-within:opacity-30 dark:group-focus-within:opacity-50 transition duration-500"></div>
                    <div class="relative flex items-center bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-white/10 overflow-hidden shadow-sm dark:shadow-2xl transition-colors">
                        <div class="pl-4 pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 group-focus-within:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input 
                            type="text" 
                            id="searchInput"
                            placeholder="Search tools..." 
                            class="w-full bg-transparent text-slate-900 dark:text-white placeholder-slate-400 px-4 py-3.5 outline-none text-base"
                        >
                        <div class="pr-4 flex items-center gap-2">
                            <button class="hidden sm:flex items-center gap-1 px-3 py-1.5 border border-slate-200 dark:border-white/10 rounded-md text-sm text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
                                Filters
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Category Carousel -->
                <div class="relative w-full max-w-full group/carousel flex items-center">
                    <div id="scrollLeftWrapper" class="absolute -left-4 md:-left-6 z-20 transition-opacity duration-300 opacity-0">
                        <button id="scrollLeftBtn" class="w-10 h-10 rounded-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:text-indigo-600 hover:border-indigo-500 transition-all shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                            </svg>
                        </button>
                    </div>
                    
                    <div class="flex overflow-x-auto hide-scrollbar snap-x snap-mandatory gap-2 py-2 px-2 scroll-smooth w-full mask-edges" id="categoryCarousel">
                        {categories.map((category) => (
                            <button 
                                class="category-pill snap-start shrink-0 whitespace-nowrap px-4 py-2 rounded-full border border-slate-200 dark:border-white/10 bg-slate-100 dark:bg-slate-900/60 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-200 dark:hover:bg-slate-800 transition-all duration-300"
                                data-category={category.toLowerCase()}
                            >
                                {category}
                            </button>
                        ))}
                    </div>
                    
                    <div id="scrollRightWrapper" class="absolute -right-4 md:-right-6 z-20 transition-opacity duration-300">
                        <button id="scrollRightBtn" class="w-10 h-10 rounded-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-white/10 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:text-indigo-600 hover:border-indigo-500 transition-all shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10 max-w-6xl mx-auto px-4" id="directoryGrid">
            {saasData.map((item) => (
                <a href={`/alternative-to/${item.slug}`} class="saas-card block group relative bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-all duration-300 shadow-sm hover:shadow-xl hover:-translate-y-1 overflow-hidden" data-name={item.name.toLowerCase()} data-category={item.category.toLowerCase()}>
                    
                    <div class="p-6 h-full flex flex-col justify-between relative z-10">
                        
                        <div>
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 font-bold text-lg border border-indigo-100 dark:border-indigo-500/20">
                                    {item.name.charAt(0)}
                                </div>
                                <div>
                                    <h2 class="text-xl font-bold text-slate-900 dark:text-white flex items-center gap-1.5">
                                        {item.name}
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-500" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                        </svg>
                                    </h2>
                                    <span class="text-xs font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded uppercase tracking-wider">{item.category}</span>
                                </div>
                            </div>
                            
                            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-2">
                                Replace proprietary and expensive {item.name} with free, open-source alternatives.
                            </p>
                        </div>
                        
                        <div class="mt-8 flex flex-col space-y-2.5 text-sm text-slate-500 dark:text-slate-400 font-mono">
                            <div class="flex justify-between items-center">
                                <span>Alternatives</span>
                                <div class="flex-grow border-b-2 border-dotted border-slate-200 dark:border-slate-700/50 mx-3 translate-y-[2px]"></div>
                                <span class="font-bold text-slate-900 dark:text-white">{item.alternatives.length} tools</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span>Total Cost</span>
                                <div class="flex-grow border-b-2 border-dotted border-slate-200 dark:border-slate-700/50 mx-3 translate-y-[2px]"></div>
                                <span class="font-bold text-emerald-600 dark:text-emerald-400">$0.00 / mo</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span>Data Privacy</span>
                                <div class="flex-grow border-b-2 border-dotted border-slate-200 dark:border-slate-700/50 mx-3 translate-y-[2px]"></div>
                                <span class="font-bold text-slate-900 dark:text-white flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                    </svg>
                                    Self-host
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
        
        <!-- Empty State -->
        <div id="emptyState" class="hidden text-center py-32 relative z-10">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-white/10 mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
            </div>
            <h3 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">No software found</h3>
            <p class="text-slate-500 dark:text-slate-400 text-lg">We haven't mapped an alternative for this tool yet.</p>
            <a href="/submit" class="mt-8 inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-xl text-white bg-indigo-600 hover:bg-indigo-700 shadow-lg shadow-indigo-500/30 transition-all">
                Submit a Request
            </a>
        </div>
    </main>

    <style>
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .mask-edges {
            -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
            mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
        }
    </style>
</Layout>

<script>
    // Client-side filtering logic
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const cards = document.querySelectorAll('.saas-card') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('emptyState');
    const pills = document.querySelectorAll('.category-pill') as NodeListOf<HTMLElement>;
    
    let currentCategory = 'all';
    let currentSearch = '';

    // Initialize pills
    pills.forEach(pill => {
        if (pill.getAttribute('data-category') === 'all') {
            pill.classList.add('bg-indigo-600', 'text-white', 'border-indigo-500', 'shadow-lg', 'shadow-indigo-500/30');
        } else {
            pill.classList.add('bg-slate-100', 'dark:bg-slate-900/60', 'text-slate-600', 'dark:text-slate-400', 'hover:text-slate-900', 'dark:hover:text-white', 'hover:bg-slate-200', 'dark:hover:bg-slate-800', 'border-slate-200', 'dark:border-white/10');
        }

        pill.addEventListener('click', () => {
            currentCategory = pill.getAttribute('data-category') || 'all';
            
            // Update active state
            pills.forEach(p => {
                p.className = 'category-pill snap-start shrink-0 whitespace-nowrap px-4 py-2 rounded-full border text-sm font-medium transition-all duration-300';
                if (p.getAttribute('data-category') === currentCategory) {
                    p.classList.add('bg-indigo-600', 'text-white', 'border-indigo-500', 'shadow-lg', 'shadow-indigo-500/30');
                } else {
                    p.classList.add('bg-slate-100', 'dark:bg-slate-900/60', 'text-slate-600', 'dark:text-slate-400', 'hover:text-slate-900', 'dark:hover:text-white', 'hover:bg-slate-200', 'dark:hover:bg-slate-800', 'border-slate-200', 'dark:border-white/10');
                }
            });

            filterCards();
        });
    });

    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
            filterCards();
        });
    }

    function filterCards() {
        let visibleCount = 0;

        cards.forEach(card => {
            const name = card.getAttribute('data-name') || '';
            const category = card.getAttribute('data-category') || '';
            
            const matchesSearch = name.includes(currentSearch) || category.includes(currentSearch);
            const matchesCategory = currentCategory === 'all' || category === currentCategory;

            if (matchesSearch && matchesCategory) {
                card.style.display = 'block';
                // Trigger a tiny reflow to restart fade-in animation
                card.style.opacity = '0';
                setTimeout(() => card.style.opacity = '1', 10);
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        if (emptyState) {
            emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
        }
    }

    // Carousel Scroll Logic
    const categoryCarousel = document.getElementById('categoryCarousel');
    const scrollLeftBtn = document.getElementById('scrollLeftBtn');
    const scrollRightBtn = document.getElementById('scrollRightBtn');
    const scrollLeftWrapper = document.getElementById('scrollLeftWrapper');
    const scrollRightWrapper = document.getElementById('scrollRightWrapper');

    if (categoryCarousel && scrollLeftBtn && scrollRightBtn) {
        const scrollAmount = 300;

        scrollLeftBtn.addEventListener('click', () => {
            categoryCarousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });

        scrollRightBtn.addEventListener('click', () => {
            categoryCarousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });

        const updateScrollButtons = () => {
            const { scrollLeft, scrollWidth, clientWidth } = categoryCarousel;
            
            if (scrollLeft > 5) {
                scrollLeftWrapper?.classList.remove('opacity-0');
            } else {
                scrollLeftWrapper?.classList.add('opacity-0');
            }

            if (Math.ceil(scrollLeft + clientWidth) >= scrollWidth - 5) {
                scrollRightWrapper?.classList.add('opacity-0');
            } else {
                scrollRightWrapper?.classList.remove('opacity-0');
            }
        };

        categoryCarousel.addEventListener('scroll', updateScrollButtons, { passive: true });
        // Initial check
        setTimeout(updateScrollButtons, 100);
        window.addEventListener('resize', updateScrollButtons);
    }
</script>
