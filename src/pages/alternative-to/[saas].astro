---
import saasData from '../../data/saas.json';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return saasData.map(item => ({
    params: { saas: item.slug },
    props: { data: item },
  }));
}

const { data } = Astro.props;
const pageTitle = `Free Open-Source Alternatives to ${data.name} (2026)`;
const pageDescription = `Stop paying for ${data.name}. Discover the best free, open-source replacements for ${data.category}.`;
---
<Layout title={pageTitle} description={pageDescription}>
    <main class="max-w-4xl mx-auto py-16 px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="mb-12">
            <a href="/" class="group inline-flex items-center text-sm font-medium text-slate-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Directory
            </a>
        </div>
        
        <div class="mb-16">
            <h1 class="text-4xl font-extrabold text-white tracking-tight sm:text-5xl mb-6">
                Top Free Alternatives to <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">{data.name}</span>
            </h1>
            <p class="text-xl text-slate-400 font-light max-w-2xl">
                Stop paying expensive subscriptions for {data.category} tools. Discover the best free and open-source replacements for {data.name}.
            </p>
        </div>

        <div class="space-y-6">
            {data.alternatives.map((alt) => (
                <div class="bg-slate-900/50 backdrop-blur-md rounded-2xl border border-white/10 overflow-hidden hover:border-indigo-500/50 transition-all duration-300 p-8 shadow-xl relative group">
                    <!-- Subtle glow on hover -->
                    <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center relative z-10">
                        <div>
                            <h2 class="text-3xl font-bold text-white group-hover:text-indigo-300 transition-colors">{alt.name}</h2>
                            <div class="flex items-center mt-3 space-x-3">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 mr-1.5"></span>
                                    {alt.pricing}
                                </span>
                            </div>
                        </div>
                        <a href={alt.url} target="_blank" rel="noopener noreferrer" class="mt-6 sm:mt-0 inline-flex items-center justify-center px-6 py-3 border border-transparent text-sm font-bold rounded-xl text-white bg-indigo-600 hover:bg-indigo-500 shadow-lg shadow-indigo-500/30 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-indigo-500">
                            Visit Website
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                        </a>
                    </div>
                    <p class="mt-6 text-slate-300 text-lg leading-relaxed relative z-10">
                        {alt.description}
                    </p>
                </div>
            ))}
        </div>
    </main>
</Layout>
